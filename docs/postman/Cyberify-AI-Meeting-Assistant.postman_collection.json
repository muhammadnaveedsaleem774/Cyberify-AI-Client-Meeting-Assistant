{
  "info": {
    "name": "Cyberify AI Client Meeting Assistant",
    "description": "Production evaluation collection for the Cyberify AI Client Meeting Assistant API. Run Auth requests first to populate tokens, then create a project, meeting, task, and AI analysis.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.accessToken) pm.environment.set('accessToken', json.data.accessToken);",
                  "if (json.data?.refreshToken) pm.environment.set('refreshToken', json.data.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo{{$timestamp}}@example.com\",\n  \"password\": \"password123\",\n  \"workspaceName\": \"Demo Workspace\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.accessToken) pm.environment.set('accessToken', json.data.accessToken);",
                  "if (json.data?.refreshToken) pm.environment.set('refreshToken', json.data.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.accessToken) pm.environment.set('accessToken', json.data.accessToken);",
                  "if (json.data?.refreshToken) pm.environment.set('refreshToken', json.data.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Workspace and Dashboard",
      "item": [
        {
          "name": "List Workspaces",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/workspaces", "host": ["{{baseUrl}}"], "path": ["workspaces"] }
          }
        },
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/dashboard/stats", "host": ["{{baseUrl}}"], "path": ["dashboard", "stats"] }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?._id) pm.environment.set('projectId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Client Portal\",\n  \"clientName\": \"Acme Corp\",\n  \"description\": \"Client self-service portal\",\n  \"status\": \"active\"\n}" },
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] }
          }
        },
        {
          "name": "List Projects With Filters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/projects?q=client&status=active",
              "host": ["{{baseUrl}}"],
              "path": ["projects"],
              "query": [
                { "key": "q", "value": "client" },
                { "key": "status", "value": "active" },
                { "key": "dateFrom", "value": "", "disabled": true },
                { "key": "dateTo", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"completed\"\n}" },
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] }
          }
        }
      ]
    },
    {
      "name": "Meetings",
      "item": [
        {
          "name": "Create Meeting",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?._id) pm.environment.set('meetingId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Discovery Meeting\",\n  \"notes\": \"We need a client portal with admin and customer roles. Customers should upload files and track project tasks.\",\n  \"date\": \"{{$isoTimestamp}}\",\n  \"projectId\": \"{{projectId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/meetings", "host": ["{{baseUrl}}"], "path": ["meetings"] }
          }
        },
        {
          "name": "List Meetings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/meetings?q=discovery",
              "host": ["{{baseUrl}}"],
              "path": ["meetings"],
              "query": [{ "key": "q", "value": "discovery" }]
            }
          }
        },
        {
          "name": "Get Meeting",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/meetings/{{meetingId}}", "host": ["{{baseUrl}}"], "path": ["meetings", "{{meetingId}}"] }
          }
        },
        {
          "name": "Update Meeting",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Discovery Meeting\"\n}" },
            "url": { "raw": "{{baseUrl}}/meetings/{{meetingId}}", "host": ["{{baseUrl}}"], "path": ["meetings", "{{meetingId}}"] }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?._id) pm.environment.set('taskId', json.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Create authentication module\",\n  \"description\": \"JWT access and refresh token flow\",\n  \"priority\": \"High\",\n  \"projectId\": \"{{projectId}}\",\n  \"meetingId\": \"{{meetingId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/tasks", "host": ["{{baseUrl}}"], "path": ["tasks"] }
          }
        },
        {
          "name": "List Tasks With Filters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?q=auth&status=Open&priority=High",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "q", "value": "auth" },
                { "key": "status", "value": "Open" },
                { "key": "priority", "value": "High" }
              ]
            }
          }
        },
        {
          "name": "Complete Task",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/tasks/{{taskId}}/complete", "host": ["{{baseUrl}}"], "path": ["tasks", "{{taskId}}", "complete"] }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["tasks", "{{taskId}}"] }
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Analyze Meeting",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"meetingId\": \"{{meetingId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/ai/analyze-meeting", "host": ["{{baseUrl}}"], "path": ["ai", "analyze-meeting"] }
          }
        },
        {
          "name": "Get Meeting Analysis",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/ai/analysis/{{meetingId}}", "host": ["{{baseUrl}}"], "path": ["ai", "analysis", "{{meetingId}}"] }
          }
        },
        {
          "name": "Delete Meeting Analysis",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/ai/analysis/{{meetingId}}", "host": ["{{baseUrl}}"], "path": ["ai", "analysis", "{{meetingId}}"] }
          }
        }
      ]
    },
    {
      "name": "Files and Activity",
      "item": [
        {
          "name": "Upload Project File",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.file?._id) pm.environment.set('fileId', json.file._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "projectId", "value": "{{projectId}}", "type": "text" },
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{baseUrl}}/files/upload", "host": ["{{baseUrl}}"], "path": ["files", "upload"] }
          }
        },
        {
          "name": "List Project Files",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/files/project/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["files", "project", "{{projectId}}"] }
          }
        },
        {
          "name": "Download File",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/files/{{fileId}}/download", "host": ["{{baseUrl}}"], "path": ["files", "{{fileId}}", "download"] }
          }
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/files/{{fileId}}", "host": ["{{baseUrl}}"], "path": ["files", "{{fileId}}"] }
          }
        },
        {
          "name": "Activity Logs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/activity-logs", "host": ["{{baseUrl}}"], "path": ["activity-logs"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "System Stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/admin/stats", "host": ["{{baseUrl}}"], "path": ["admin", "stats"] }
          }
        }
      ]
    }
  ]
}
