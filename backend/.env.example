DATABASE_URL=mongodb://localhost:27017/cyberify
JWT_SECRET=replace-with-a-long-random-secret
PORT=4000
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
APP_NAME=Cyberify AI Client Meeting Assistant
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET_NAME=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Cyberify <no-reply@cyberify.local>

# Optional: preferred SendGrid HTTPS API path. If set, SMTP is skipped.
SENDGRID_API_KEY=

# Optional: SendGrid SMTP fallback. If only SENDGRID_API_KEY is set, SMTP_HOST/SMTP_USER/SMTP_PASS are inferred.

# AI provider priority: Groq, then OpenAI, then Gemini.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
